@using Microsoft.AspNetCore.Http
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@model ASPNET_CourseProject.Models.View.ArtUploadModel

@{
    string username = HttpContextAccessor.HttpContext.Session.GetString("UserName");
}

<h1>Upload</h1>

<div class="container form-container" style="max-width: 50vh">
    @using (Html.BeginForm("Upload", "Art", FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
        <div class="form-outline flex-fill mb-3">
            @Html.LabelFor(Model => Model.Image, htmlAttributes: new { @class = "form-label", @for = "image-upload" })
            @Html.TextBoxFor(Model => Model.Image, htmlAttributes: new { @type = "file", @class = "form-control form-control-lg", id = "image-upload", required = "required", accept = "image/jpeg,image/png" })
        </div>
        <div class="form-floating form-outline flex-fill mb-3">
            @Html.TextBoxFor(Model => Model.ArtDTO.Title, htmlAttributes: new { @class = "form-control", id = "title", placeholder = "Title", required = "required" })
            @Html.LabelFor(Model => Model.ArtDTO.Title, htmlAttributes: new { @class = "form-label", @for = "title" })
        </div>
        <div class="form-floating form-outline flex-fill mb-3">
            @Html.TextAreaFor(Model => Model.ArtDTO.Description, htmlAttributes: new { @class = "form-control", id = "descr", placeholder = "Description" })
            @Html.LabelFor(Model => Model.ArtDTO.Description, htmlAttributes: new { @class = "form-label", @for = "title" })
        </div>
        @Html.HiddenFor(Model => Model.Username, htmlAttributes: new { Value = username })
        ;
        <button type="submit" class="btn btn-primary w-100 mb-4">Submit</button>
    }
</div>
